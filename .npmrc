# Route the @ember-coding scope to the private registry; everything else
# continues to resolve from the public npm registry.
@ember-coding:registry=https://npm.internal.ember-coding.com/

# Auth token is read from the environment so no secret is committed.
# Export NPM_TOKEN before `npm publish` / `npm install`, e.g. in CI:
#   export NPM_TOKEN=...
//npm.internal.ember-coding.com/:_authToken=${NPM_TOKEN}
